# BNI Trainer Feedback System — 환경 변수 예시
# 이 파일을 복사해 .env.local로 사용하세요. 실제 값은 커밋하지 않습니다.

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Notion — 피드백 저장용 데이터베이스
NOTION_API_KEY=
NOTION_FEEDBACK_DATABASE_ID=

# Notion — 교육 템플릿(드롭다운 목록) 데이터베이스
NOTION_TRAINING_TEMPLATE_DATABASE_ID=

# 관리자 페이지(/admin) 비밀번호 — 완전한 보안 방식은 아니며 V1 운영용입니다
NEXT_PUBLIC_ADMIN_PASSWORD=

# n8n Webhook (예정)
N8N_WEBHOOK_URL=
N8N_WEBHOOK_SECRET=

# OpenAI — 피드백 AI 분석
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
