# BNI Trainer Feedback System — 환경 변수 예시
# 이 파일을 복사해 .env.local로 사용하세요. 실제 값은 커밋하지 않습니다.

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Notion — 피드백 저장용 데이터베이스
NOTION_API_KEY=
NOTION_FEEDBACK_DATABASE_ID=

# Notion — 교육 템플릿(드롭다운 목록) 데이터베이스
NOTION_TRAINING_TEMPLATE_DATABASE_ID=

# n8n Webhook (예정)
N8N_WEBHOOK_URL=
N8N_WEBHOOK_SECRET=

# AI 분석 (예정, 사용할 제공자는 추후 결정)
AI_API_KEY=
