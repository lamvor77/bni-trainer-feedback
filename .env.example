# BNI Trainer Feedback System — 환경 변수 예시
# 이 파일을 복사해 .env.local로 사용하세요. 실제 값은 커밋하지 않습니다.

# Notion — 피드백 저장용 데이터베이스 (TASK-005)
NOTION_API_KEY=
NOTION_FEEDBACK_DATABASE_ID=

# Notion — 교육 템플릿(드롭다운 목록) 데이터베이스 (TASK-006)
NOTION_TRAINING_TEMPLATE_DATABASE_ID=

# Notion — AI 분석 리포트 저장용 데이터베이스 (TASK-012)
NOTION_ANALYSIS_REPORT_DATABASE_ID=

# OpenAI — 피드백 AI 분석 (TASK-011)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# 관리자 페이지(/admin) 비밀번호 — 완전한 보안 방식은 아니며 V1 운영용입니다 (TASK-008)
NEXT_PUBLIC_ADMIN_PASSWORD=
